# Divination Studio of Zhou Xiaotong
# Environment Variables Configuration

# PostgreSQL Database URL (Required)
# Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Supabase: postgresql://postgres:password@xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@host:5432/dbname"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Site URL (Required for SEO)
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Admin secret for admin dashboard access
ADMIN_SECRET="change-this-to-a-secure-random-string"

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Payment Provider (simulated | xorpay)
PAYMENT_PROVIDER=simulated
# XORPAY_API_KEY=your_xorpay_api_key
# XORPAY_API_SECRET=your_xorpay_api_secret
