      "pinyin": "Shui Feng Jing",
      "upper": "坎",
      "lower": "巽",
      "element": "水",
      "judgment": "改邑不改井，无丧无得。",
      "meaning": "守常不变，滋养万物。象征源泉、滋养、恒常。",
      "advice": "已有的资源需要妥善管理和维护。"
    },
    "49": {
      "name": "泽火革",
      "pinyin": "Ze Huo Ge",
      "upper": "兑",
      "lower": "离",
      "element": "金",
      "judgment": "已日乃孚。元亨利贞。",
      "meaning": "变革创新，除旧布新。象征变革、革命、革新。",
      "advice": "变革时机已到，当除旧布新。"
    },
    "50": {
      "name": "火风鼎",
      "pinyin": "Huo Feng Ding",
      "upper": "离",
      "lower": "巽",
      "element": "火",
      "judgment": "元吉，亨。",
      "meaning": "鼎立革新，烹饪新象。象征革新、确立、烹饪。",
      "advice": "鼎象征权力和文明的建立。"
    },
    "51": {
      "name": "震为雷",
      "pinyin": "Zhen Wei Lei",
      "upper": "震",
      "lower": "震",
      "element": "木",
      "judgment": "亨。震惊百里，不丧匕鬯。",
      "meaning": "震惊雷动，临危不乱。象征震动、警惕、奋起。",
      "advice": "保持镇定即可化险为夷。"
    },
    "52": {
      "name": "艮为山",
      "pinyin": "Gen Wei Shan",
      "upper": "艮",
      "lower": "艮",
      "element": "土",
      "judgment": "艮其背，不获其身。",
      "meaning": "止静如山，适可而止。象征静止、停止、反思。",
      "advice": "此时宜静不宜动。适可而止也是一种智慧。"
    },
    "53": {
      "name": "风山渐",
      "pinyin": "Feng Shan Jian",
      "upper": "巽",
      "lower": "艮",
      "element": "木",
      "judgment": "女归吉，利贞。",
      "meaning": "循序渐进，步步为营。象征渐进、积累、发展。",
      "advice": "欲速则不达。凡事循序渐进，自然水到渠成。"
    },
    "54": {
      "name": "雷泽归妹",
      "pinyin": "Lei Ze Gui Mei",
      "upper": "震",
      "lower": "兑",
      "element": "木",
      "judgment": "征凶，无攸利。",
      "meaning": "错位姻缘，名不正则言不顺。象征错位、不正当。",
      "advice": "名分和位置很重要。如果位置不对则难以长久。"
    },
    "55": {
      "name": "雷火丰",
      "pinyin": "Lei Huo Feng",
      "upper": "震",
      "lower": "离",
      "element": "木",
      "judgment": "亨。王假之，勿忧。",
      "meaning": "丰盛盈满，如日中天。象征丰盛、富足、盛大。",
      "advice": "如日中天，气势旺盛。但盛极必衰，宜居安思危。"
    },
    "56": {
      "name": "火山旅",
      "pinyin": "Huo Shan Lu",
      "upper": "离",
      "lower": "艮",
      "element": "火",
      "judgment": "旅，小亨。旅贞吉。",
      "meaning": "漂泊旅居，客居他乡。象征旅行、漂泊、临时。",
      "advice": "人生如旅，漂泊不定。旅途中宜谨慎行事。"
    },
    "57": {
      "name": "巽为风",
      "pinyin": "Xun Wei Feng",
      "upper": "巽",
      "lower": "巽",
      "element": "木",
      "judgment": "小亨。利有攸往。",
      "meaning": "顺势而行，无孔不入。象征顺从、渗透、灵活。",
      "advice": "随风而动，顺势而为。"
    },
    "58": {
      "name": "兑为泽",
      "pinyin": "Dui Wei Ze",
      "upper": "兑",
      "lower": "兑",
      "element": "金",
      "judgment": "亨，利贞。",
      "meaning": "喜悦交流，和颜悦色。象征喜悦、交流、言语。",
      "advice": "以喜悦之心待人，用温和的语言交流。"
    },
    "59": {
      "name": "风水涣",
      "pinyin": "Feng Shui Huan",
      "upper": "巽",
      "lower": "坎",
      "element": "木",
      "judgment": "亨。王假有庙。",
      "meaning": "涣散离散，聚心合力。象征涣散、离散、消解。",
      "advice": "人心涣散时需要重新凝聚力量。"
    },
    "60": {
      "name": "水泽节",
      "pinyin": "Shui Ze Jie",
      "upper": "坎",
      "lower": "兑",
      "element": "水",
      "judgment": "亨。苦节不可贞。",
      "meaning": "节制适度，过犹不及。象征节制、限制、适度。",
      "advice": "凡事有度，过犹不及。懂得节制是智慧。"
    },
    "61": {
      "name": "风泽中孚",
      "pinyin": "Feng Ze Zhong Fu",
      "upper": "巽",
      "lower": "兑",
      "element": "木",
      "judgment": "豚鱼吉。利涉大川。",
      "meaning": "内怀诚信，感化万物。象征诚信、真心、信念。",
      "advice": "真诚之心可以感动万物。"
    },
    "62": {
      "name": "雷山小过",
      "pinyin": "Lei Shan Xiao Guo",
      "upper": "震",
      "lower": "艮",
      "element": "木",
      "judgment": "亨，利贞。不宜上宜下。",
      "meaning": "小有过失，宜守本分。象征小错、适度、守常。",
      "advice": "小事可过，大事不可过。安守本分。"
    },
    "63": {
      "name": "水火既济",
      "pinyin": "Shui Huo Ji Ji",
      "upper": "坎",
      "lower": "离",
      "element": "水",
      "judgment": "亨小，利贞。初吉终乱。",
      "meaning": "功成名就，守成更难。象征完成、成功、圆满。",
      "advice": "守成比创业更难。宜居安思危，防止由盛转衰。"
    },
    "64": {
