generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Divination records
model DivinationRecord {
  id        String   @id @default(cuid())
  method    String
  question  String
  result    String
  createdAt DateTime @default(now())
  codeId    String?
  code      RedemptionCode? @relation(fields: [codeId], references: [id])

  @@index([method])
  @@index([createdAt])
  @@index([codeId])
  @@map("divination_records")
}

// Payment orders from WeChat Pay
model PaymentOrder {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  amount      Int      // amount in yuan (1 = 1 yuan)
  turnCount   Int      // how many turns this purchase gives
  status      String   @default("pending") // pending | paid | expired
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  code        RedemptionCode?

  @@index([orderNo])
  @@index([status])
  @@map("payment_orders")
}

// Redemption codes (取次码)
model RedemptionCode {
  id          String   @id @default(cuid())
  code        String   @unique
  totalTurns  Int      @default(1)
  usedTurns   Int      @default(0)
  status      String   @default("active") // active | exhausted | expired
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
  paymentId   String?  @unique
  payment     PaymentOrder? @relation(fields: [paymentId], references: [id])
  records     DivinationRecord[]

  @@index([code])
  @@index([status])
  @@map("redemption_codes")
}
